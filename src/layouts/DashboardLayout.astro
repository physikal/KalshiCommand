---
import "../styles/global.css";

interface Props {
  title: string;
  active?: string;
}

const { title, active } = Astro.props;

const navItems = [
  { href: "/", label: "Dashboard", icon: "chart" },
  { href: "/trades", label: "Trades", icon: "list" },
  { href: "/positions", label: "Positions", icon: "target" },
  { href: "/settlements", label: "Settlements", icon: "check" },
  { href: "/analytics", label: "Analytics", icon: "trend" },
  { href: "/taxes", label: "Taxes", icon: "receipt" },
  { href: "/docs/overview", label: "Docs", icon: "book" },
];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Kalshi Command Center</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-surface-950 text-surface-50 min-h-screen md:flex">
    <nav
      class="fixed bottom-0 left-0 right-0 z-50 border-t border-surface-800 bg-surface-900/95 backdrop-blur md:static md:border-r md:border-t-0 md:w-56 md:min-h-screen md:flex-shrink-0"
    >
      <div class="hidden md:block px-5 py-5">
        <h1 class="text-lg font-bold text-brand-400 tracking-tight">
          Kalshi CC
        </h1>
        <p class="text-xs text-surface-700 mt-0.5">Command Center</p>
      </div>
      <ul class="flex md:flex-col justify-around md:justify-start md:gap-1 md:px-3">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "flex flex-col md:flex-row items-center md:gap-3 px-2 py-3 md:px-3 md:py-2.5 rounded-lg text-xs md:text-sm transition-colors",
                active === item.label
                  ? "text-brand-400 bg-brand-950/50"
                  : "text-surface-200 hover:text-brand-300 hover:bg-surface-800",
              ]}
            >
              <svg class="w-5 h-5 md:w-4 md:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                {item.icon === "chart" && <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />}
                {item.icon === "list" && <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />}
                {item.icon === "target" && <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />}
                {item.icon === "check" && <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />}
                {item.icon === "trend" && <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />}
                {item.icon === "receipt" && <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />}
                {item.icon === "book" && <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />}
              </svg>
              <span>{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <main class="pb-20 md:pb-0 flex-1 min-w-0">
      <div class="px-4 py-6 md:px-8 md:py-8 max-w-7xl mx-auto">
        <slot />
      </div>
    </main>
  </body>
</html>
