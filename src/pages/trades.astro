---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import TradesTable from "../components/TradesTable";
import { getAllFillsFromDb } from "../lib/db";
import { startAutoSync } from "../lib/sync";

startAutoSync();

let fills: any[] = [];
let error = null;

try {
  fills = getAllFillsFromDb();
} catch (e) {
  error = e instanceof Error ? e.message : "Failed to load trades";
}
---

<DashboardLayout title="Trades" active="Trades">
  <div class="mb-6">
    <h2 class="text-xl md:text-2xl font-bold tracking-tight">Trade Log</h2>
    <p class="text-surface-700 text-sm mt-1">All executed fills from your portfolio</p>
  </div>
  {error ? (
    <div class="rounded-xl bg-loss/10 border border-loss/30 p-4 text-loss text-sm">
      {error}
    </div>
  ) : (
    <TradesTable fills={fills} client:load />
  )}
</DashboardLayout>
